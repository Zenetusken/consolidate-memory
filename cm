#!/usr/bin/env bash
# cm — dev entry point for the consolidate-memory tool. Thin dispatcher over the
# plugin's scripts (plugins/consolidate-memory/scripts/) so a maintainer can drive a
# pass (or inspect the network) from the shell without the plugin being installed.
set -euo pipefail
HERE="$(cd "$(dirname "$(readlink -f "$0")")" && pwd)"   # readlink -f → resolve a PATH symlink to the real repo (so `cm` works installed on PATH)
S="$HERE/plugins/consolidate-memory/scripts"
cmd="${1:-help}"; shift || true

case "$cmd" in
  status)   exec python3 "$S/memory_status.py" "$@" ;;            # Phase 0 context
  seed)     exec python3 "$S/memory_status.py" --json "$@" ;;     # cycle-record seed
  extract)  exec python3 "$S/extract_signals.py" "$@" ;;          # Phase 2 session signal
  distill)  exec python3 "$S/distill_scan.py" "$@" ;;             # Phase-5 distill: recurring workflow templates
  sync)     exec python3 "$S/sync_global.py" "$@" ;;              # --list/--pull PROJECT_DIR
  pull)     exec python3 "$S/sync_global.py" --pull "${1:-.}" ;;  # replicate globals here
  gc)       exec python3 "$S/sync_global.py" --gc "$@" ;;         # reclaim orphan mirrors (+ --apply)
  promote)  exec python3 "$S/sync_global.py" --promote "$@" ;;    # DIR LOCAL_FACT [CANON]: local→canonical hand-off
  tokens)   exec python3 "$S/sync_global.py" --tokens "$@" ;;     # network token consumption (+ --json)
  network)  exec python3 "$S/sync_global.py" --network ;;         # shared-consciousness graph
  render)   exec python3 "$S/render_dashboard.py" "$@" ;;         # cycle.json -> ASCII dashboard
  report)   if [ -d "${1:-}" ]; then exec python3 "$S/render_html.py" --project "$1"; elif echo "${1:-}" | grep -qE '^[0-9a-f]{4,40}$'; then exec python3 "$S/render_html.py" --select "$1" --project "${2:-.}"; else exec python3 "$S/render_html.py" --project "${1:-.}"; fi ;;  # existing dir → its archive · hex → a dream by hash · else cwd archive
  log)      if [ -d "${1:-}" ]; then D="$1"; shift; else D="."; fi; exec python3 "$S/render_log.py" --project "$D" "$@" ;;  # lean per-dream audit table ([-n N] / --json pass through)
  help|*)
    cat <<EOF
cm — consolidate-memory

  cm status [DIR]      Phase-0 context (stores, git range, marker)
  cm extract [--json]  curated session signal (human turns + error gotchas)
  cm distill [DIR]     recurring Bash-command workflow templates + chains (the distill phase's scan;
                       [--since ISO] [--json]; --into SEED injects the counts into a cycle record)
  cm sync --list DIR   show which global facts apply to a project
  cm pull [DIR]        replicate relevant global facts into a project (default: .)
  cm gc [DIR] [--apply] reclaim orphaned mirrors (report-only without --apply)
  cm promote DIR FACT [CANON]  hand a local fact up to the global store + mirror the origin
  cm tokens [DIR] [--json] per-node + total token consumption across the network
  cm network           render the cross-project shared-memory graph
  cm render cycle.json render an ASCII dashboard from a cycle record
  cm report [DIR]      [maintainer dev CLI] open DIR's dream archive (DEFAULT: THIS repo — pass another
                       repo's path to view it, e.g. cm report ~/project/job-applicator-python).
                       End users just open ~/.claude/projects/<slug>/dashboards/index.html directly.
  cm report HASH [DIR] re-open a specific dream's dashboard by its commit-hash prefix
  cm log [DIR] [-n N]  dense per-dream audit TABLE over DIR's .consolidation-log.jsonl (DEFAULT: THIS repo);
                       add --json for the raw cycle records (pipe to jq). The 3rd view of the dream log.

A full pass is best driven by the plugin itself. Dogfood it from this repo:
  claude plugin marketplace add .
  claude plugin install consolidate-memory@zenetusken-plugins
then say "dream" in any project. See README.md.
EOF
    ;;
esac
