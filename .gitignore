# The shared-consciousness memory stream is personal — NEVER publish it. Keep the dir
# but ignore its contents. This dir lives at the repo root, OUTSIDE
# plugins/consolidate-memory/, so it is never bundled into the published plugin
# (the plugin = plugins/consolidate-memory/ only).
memory/*
!memory/.gitkeep

# Operational state + logs written by the skill (high-water mark, calibration log, mutation
# audit trail) — never facts, never published. Defense-in-depth: the private store lives at
# ~/.claude/projects/<slug>/memory/ (out of tree) AND this repo dogfoods itself, so guard the
# names too in case a path ever points in-tree (this is a PUBLIC repo).
**/.consolidation-state.json
**/.consolidation-log.jsonl
**/.mutation-log.jsonl

# Python + workspace cruft (covers plugins/consolidate-memory/scripts/__pycache__/).
__pycache__/
*.pyc
*-workspace/
# mypy is a DEV-ONLY maintainer tool (the cycle-record contract check); its cache lands
# at the repo root when run — never publish it to this public no-cruft repo.
.mypy_cache/

# Backup files (e.g. <name>.bak.<timestamp>) — never publish them if they appear in-tree.
*.bak.*

# OS / editor cruft.
.DS_Store
*.swp
.idea/
.vscode/

# Maintainer security tooling + audit findings are LOCAL-only — never publish them to
# this public repo. Only the defensive posture (SECURITY.md, at the repo root) is public.
security/

# Local maintainer release tool (auto-update release cycle) — not published.
release.sh

# Internal go-live checklist — maintainer-only, not published.
PREFLIGHT.md
